@{
    ViewData["Title"] = "About";
    bool isAr = System.Threading.Thread.CurrentThread.CurrentCulture.Name == "ar";
}

<div class="container py-5">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h2>@(isAr ? "من نحن" : "About Us")</h2>
            <p class="lead">
                @(isAr
                                ? "إيجي جروب شركة رائدة في تقديم أفضل المنتجات والعلامات التجارية."
                                : "Egygroup is a leading company providing the best products and brands.")
            </p>
        </div>
        <div class="col-md-6 text-center">
            <img src="~/images/about.jpg" class="img-fluid rounded shadow" alt="About Us" />
        </div>
    </div>
</div>