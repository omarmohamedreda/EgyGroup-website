<!DOCTYPE html>
@{
    var currentCulture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isArabic = currentCulture.StartsWith("ar");
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}
<html lang="@(isArabic ? "ar" : "en")" dir="@(isArabic ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Egygroup</title>
    <script type="importmap"></script>
    @if (isArabic)
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" />
    }
    else
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Egygroup.PL.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        body {
            font-family: 'Cairo', sans-serif;
            margin: 0;
            padding: 0;
        }

        .main-navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(0,0,0,0.08);
            transition: box-shadow 0.3s ease;
        }

            .main-navbar.scrolled {
                box-shadow: 0 4px 24px rgba(13,71,161,0.10);
            }

        .navbar-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 32px !important;
            max-width: 1600px;
            margin: 0 auto;
            gap: 24px;
        }

        .navbar-logo img {
            height: 75px !important;
            width: auto;
            object-fit: contain;
        }

        .navbar-links {
            display: flex;
            align-items: center;
            gap: 6px;
            list-style: none;
            margin: 0;
            padding: 0;
            flex: 1;
            justify-content: center;
        }

            .navbar-links a {
                display: block;
                padding: 8px 16px;
                border-radius: 10px;
                color: #2d3748;
                text-decoration: none;
                font-size: 0.95rem;
                font-weight: 600;
                transition: all 0.2s ease;
                white-space: nowrap;
            }

                .navbar-links a:hover, .navbar-links a.active {
                    background: rgba(26,111,189,0.08);
                    color: #1a6fbd;
                }

        .navbar-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .lang-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            background: transparent;
            border: 1.5px solid #dee2e6;
            border-radius: 10px;
            padding: 7px 14px;
            font-size: 0.88rem;
            font-weight: 600;
            color: #4a5568;
            cursor: pointer;
            transition: all 0.2s ease;
            font-family: 'Cairo', sans-serif;
        }

            .lang-btn:hover {
                border-color: #1a6fbd;
                color: #1a6fbd;
                background: rgba(26,111,189,0.05);
            }

        .lang-dropdown {
            position: relative;
        }

        .lang-dropdown-menu {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.12);
            min-width: 150px;
            padding: 6px;
            display: none;
            z-index: 9999;
        }

        [dir="rtl"] .lang-dropdown-menu {
            right: auto;
            left: 0;
        }

        .lang-dropdown:hover .lang-dropdown-menu,
        .lang-dropdown.open .lang-dropdown-menu {
            display: block;
        }

        .lang-dropdown-menu a {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border-radius: 8px;
            color: #2d3748;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 600;
            transition: background 0.15s ease;
        }

            .lang-dropdown-menu a:hover {
                background: #f0f6ff;
                color: #1a6fbd;
            }

            .lang-dropdown-menu a.active {
                background: #e8f1fb;
                color: #1a6fbd;
            }

        .navbar-toggler-btn {
            display: none;
            background: none;
            border: 1.5px solid #dee2e6;
            border-radius: 8px;
            padding: 6px 10px;
            cursor: pointer;
            color: #4a5568;
            font-size: 1.1rem;
        }

        @@media (max-width: 768px) {
            .navbar-toggler-btn {
                display: flex;
                align-items: center;
            }

            .navbar-links {
                display: none;
                flex-direction: column;
                gap: 4px;
            }

                .navbar-links.open {
                    display: flex;
                }

            .navbar-inner {
                flex-wrap: wrap;
                padding: 12px 16px;
            }

            .navbar-links {
                width: 100%;
                border-top: 1px solid #eee;
                padding-top: 8px;
            }

                .navbar-links a {
                    padding: 10px 12px;
                }
        }

        .page-content {
            padding-top: 107px;
        }
    </style>
</head>
<body>

    <nav class="main-navbar" id="mainNav">
        <div class="navbar-inner">
            <a class="navbar-logo" asp-controller="Home" asp-action="Index">
                <img src="~/images/Logo.png" alt="egy group" />
            </a>

            <button class="navbar-toggler-btn" id="navToggler">
                <i class="bi bi-list"></i>
            </button>

            <ul class="navbar-links" id="navLinks">
                <li>
                    <a asp-controller="Home" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                        @(isArabic ? "الرئيسية" : "Home")
                    </a>
                </li>
                <li>
                    <a asp-controller="Products" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")">
                        @(isArabic ? "المنتجات" : "Products")
                    </a>
                </li>
                <li>
                    <a asp-controller="About" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "About" ? "active" : "")">
                        @(isArabic ? "عن الشركة" : "About Us")
                    </a>
                </li>
            </ul>

            <div class="navbar-actions">
                <div class="lang-dropdown" id="langDropdown">
                    <button class="lang-btn" id="langBtn">
                        <i class="bi bi-globe2"></i>
                        @(isArabic ? "العربية" : "English")
                        <i class="bi bi-chevron-down" style="font-size:0.7rem;"></i>
                    </button>
                    <div class="lang-dropdown-menu">
                        <a href="/language/set/en?returnUrl=@returnUrl" class="@(!isArabic ? "active" : "")">
                            🇬🇧 English
                        </a>
                        <a href="/language/set/ar?returnUrl=@returnUrl" class="@(isArabic ? "active" : "")">
                            🇸🇦 العربية
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="page-content">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        window.addEventListener('scroll', () => {
            document.getElementById('mainNav').classList.toggle('scrolled', window.scrollY > 20);
        });
        document.getElementById('navToggler').addEventListener('click', () => {
            document.getElementById('navLinks').classList.toggle('open');
        });
        document.getElementById('langBtn').addEventListener('click', () => {
            document.getElementById('langDropdown').classList.toggle('open');
        });
        document.addEventListener('click', (e) => {
            if (!document.getElementById('langDropdown').contains(e.target)) {
                document.getElementById('langDropdown').classList.remove('open');
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>