<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Egygroup Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        body { background-color: #f1f3f5; }
        .sidebar {
            width: 240px; min-width: 240px;
            min-height: 100vh;
            background-color: #1a1d21;
        }
        .sidebar .brand { color: #fff; font-weight: 700; font-size: 1.1rem; }
        .sidebar .nav-link { color: #adb5bd; border-radius: .375rem; padding: .5rem 1rem; }
        .sidebar .nav-link:hover { color: #fff; background-color: #2c3034; }
        .sidebar .nav-link.active { color: #fff; background-color: #0d6efd; }
    </style>
</head>
<body>
    <div class="d-flex">

        <!-- Sidebar -->
        <div class="sidebar p-3 d-flex flex-column">
            <div class="brand px-2 mb-4">
                <i class="bi bi-grid-fill me-2"></i>Admin Panel
            </div>

            <nav class="d-flex flex-column gap-1 flex-grow-1">
                <a asp-controller="AdminBrands" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminBrands" ? "active" : "")">
                    <i class="bi bi-tags me-2"></i>Brands
                </a>
                <a asp-controller="AdminProducts" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminProducts" ? "active" : "")">
                    <i class="bi bi-box-seam me-2"></i>Products
                </a>
            </nav>

            <div class="border-top border-secondary pt-3 mt-3">
                <a asp-controller="Home" asp-action="Index" class="nav-link mb-1">
                    <i class="bi bi-house me-2"></i>Back to Site
                </a>
                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="nav-link btn btn-link p-0 w-100 text-start">
                        <i class="bi bi-box-arrow-left me-2"></i>Logout
                    </button>
                </form>
            </div>
        </div>

        <!-- Content -->
        <div class="flex-grow-1 p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>

    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>