@model Egygroup.BLL.DTOS.ProductDto

@{
    ViewData["Title"] = "Product Details";
    bool isAr = System.Threading.Thread.CurrentThread.CurrentCulture.Name == "ar";
}

<div class="container py-5">
    <div class="row">
        <div class="col-md-5">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid rounded shadow" alt="@Model.NameEn" />
            }
        </div>
        <div class="col-md-7">
            <h2>@(isAr? Model.NameAr: Model.NameEn)</h2>
            <p class="text-muted">
                @(isAr ? "العلامة التجارية:" : "Brand:")
                <strong>@(isAr? Model.BrandNameAr: Model.BrandNameEn)</strong>
            </p>
            <p>@(isAr? Model.DescriptionAr: Model.DescriptionEn)</p>
            <a href="/products/brand/@Model.BrandId" class="btn btn-outline-secondary mt-3">
                @(isAr ? "← رجوع للعلامة التجارية" : "← Back to Brand")
            </a>
        </div>
    </div>
</div>