@model Egygroup.PL.ViewModels.BrandViewModel

<div class="card shadow-sm border-0" style="max-width:680px">
    <div class="card-body">

        <!-- Language Tabs -->
        <ul class="nav nav-tabs mb-4">
            <li class="nav-item">
                <a class="nav-link active" data-bs-toggle="tab" href="#tab-en">
                    🇬🇧 English
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#tab-ar">
                    🇸🇦 العربية
                </a>
            </li>
        </ul>

        <div class="tab-content">
            <!-- English -->
            <div class="tab-pane fade show active" id="tab-en">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Name (English) <span class="text-danger">*</span></label>
                    <input asp-for="NameEn" class="form-control" placeholder="e.g. Samsung" />
                    <span asp-validation-for="NameEn" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description (English)</label>
                    <textarea asp-for="DescriptionEn" class="form-control" rows="3"
                              placeholder="Brief description..."></textarea>
                </div>
            </div>

            <!-- Arabic -->
            <div class="tab-pane fade" id="tab-ar" dir="rtl">
                <div class="mb-3">
                    <label class="form-label fw-semibold">الاسم (عربي) <span class="text-danger">*</span></label>
                    <input asp-for="NameAr" class="form-control text-end" placeholder="مثال: سامسونج" />
                    <span asp-validation-for="NameAr" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">الوصف (عربي)</label>
                    <textarea asp-for="DescriptionAr" class="form-control text-end" rows="3"
                              placeholder="وصف مختصر..."></textarea>
                </div>
            </div>
        </div>

        <!-- Logo Upload -->
        <div class="mb-4">
            <label class="form-label fw-semibold">Logo</label>
            @if (!string.IsNullOrEmpty(Model.LogoUrl))
            {
                <div class="mb-2">
                    <img src="@Model.LogoUrl" height="60" class="rounded border" />
                    <span class="text-muted small ms-2">Current logo</span>
                </div>
                <input type="hidden" asp-for="LogoUrl" />
            }
            <input asp-for="LogoFile" type="file" class="form-control" accept="image/*" />
            <div class="form-text">Accepted: JPG, PNG, SVG. Max 2MB.</div>
        </div>

        <!-- Buttons -->
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-lg me-1"></i>Save
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>

    </div>
</div>