@model Egygroup.BLL.DTOS.BrandDto
@{
    ViewData["Title"] = "Delete Brand"; Layout = "_AdminLayout";
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none text-muted">
        <i class="bi bi-arrow-left me-1"></i>Back to Brands
    </a>
    <h4 class="fw-bold mt-2 text-danger">Delete Brand</h4>
</div>

<div class="card border-danger shadow-sm" style="max-width:500px">
    <div class="card-body">
        <p class="mb-1 text-muted">Are you sure you want to delete:</p>
        <h5 class="fw-bold">@Model.NameEn <span class="text-muted">/ @Model.NameAr</span></h5>

        @if (!string.IsNullOrEmpty(Model.LogoUrl))
        {
            <img src="@Model.LogoUrl" height="60" class="rounded my-3" />
        }

        <div class="alert alert-warning mt-3">
            <i class="bi bi-exclamation-triangle me-2"></i>
            This will also delete all products under this brand.
        </div>

        <div class="d-flex gap-2 mt-3">
            <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i>Yes, Delete
                </button>
            </form>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div>
</div>