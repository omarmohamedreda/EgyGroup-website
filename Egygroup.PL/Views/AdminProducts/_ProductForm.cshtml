@model Egygroup.PL.ViewModels.ProductViewModel

<div class="card shadow-sm border-0" style="max-width:680px">
    <div class="card-body">

        <ul class="nav nav-tabs mb-4">
            <li class="nav-item">
                <a class="nav-link active" data-bs-toggle="tab" href="#tab-en">🇬🇧 English</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#tab-ar">🇸🇦 العربية</a>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="tab-en">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Name (English) <span class="text-danger">*</span></label>
                    <input asp-for="NameEn" class="form-control" placeholder="e.g. Galaxy S24" />
                    <span asp-validation-for="NameEn" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description (English)</label>
                    <textarea asp-for="DescriptionEn" class="form-control" rows="3"></textarea>
                </div>
            </div>

            <div class="tab-pane fade" id="tab-ar" dir="rtl">
                <div class="mb-3">
                    <label class="form-label fw-semibold">الاسم (عربي) <span class="text-danger">*</span></label>
                    <input asp-for="NameAr" class="form-control text-end" />
                    <span asp-validation-for="NameAr" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">الوصف (عربي)</label>
                    <textarea asp-for="DescriptionAr" class="form-control text-end" rows="3"></textarea>
                </div>
            </div>
        </div>

        <!-- Brand Dropdown -->
        <div class="mb-3">
            <label class="form-label fw-semibold">Brand <span class="text-danger">*</span></label>
            <select asp-for="BrandId" class="form-select"
                    asp-items="@(new SelectList(ViewBag.Brands, "Id", "NameEn"))">
                <option value="">— Select Brand —</option>
            </select>
            <span asp-validation-for="BrandId" class="text-danger small"></span>
        </div>

        <!-- Image Upload -->
        <div class="mb-3">
            <label class="form-label fw-semibold">Product Image</label>
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="mb-2">
                    <img src="@Model.ImageUrl" height="80" class="rounded border" />
                    <span class="text-muted small ms-2">Current image</span>
                </div>
                <input type="hidden" asp-for="ImageUrl" />
            }
            <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
        </div>

        <!-- IsActive Toggle -->
        <div class="mb-4">
            <div class="form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                <label class="form-check-label fw-semibold" asp-for="IsActive">Active</label>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-lg me-1"></i>Save
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>

    </div>
</div>