@model Egygroup.PL.ViewModels.ProductViewModel
@{
    ViewData["Title"] = "Add Product"; Layout = "_AdminLayout";
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none text-muted">
        <i class="bi bi-arrow-left me-1"></i>Back to Products
    </a>
    <h4 class="fw-bold mt-2">Add New Product</h4>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <partial name="_ProductForm" model="Model" />
</form>